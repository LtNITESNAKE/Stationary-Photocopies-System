@model IEnumerable<PhotocopySystem.Models.OrderItem>

@{
    ViewData["Title"] = "Order Details";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold" style="color: #2c3e50;">
            <i class="bi bi-list-check me-2"></i>Items in this Order
        </h2>
        <a asp-controller="Orders" asp-action="Index" class="btn btn-primary shadow-sm rounded-pill px-4 py-2">
            <i class="bi bi-arrow-left me-1"></i> Back to Orders
        </a>
    </div>

    <div class="card shadow-lg border-0" style="border-radius: 15px; overflow: hidden;">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
                        <tr>
                            <th class="py-3 px-4">Product Name</th>
                            <th class="py-3 px-4">Quantity</th>
                            <th class="py-3 px-4">Unit Price</th>
                            <th class="py-3 px-4">Total</th>
                            <th class="py-3 px-4 text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="px-4 fw-semibold text-dark">@item.Product?.Name</td>
                                <td class="px-4 text-muted">@item.Quantity</td>
                                <td class="px-4 text-muted">@item.UnitPrice</td>
                                <td class="px-4">
                                    <span class="badge bg-success bg-opacity-10 text-success px-3 py-2 rounded-pill">
                                        @(item.Quantity * item.UnitPrice)
                                    </span>
                                </td>
                                <td class="px-4 text-center">
                                    <button class="btn btn-sm btn-outline-danger rounded-circle">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .table-hover tbody tr:hover {
        background-color: #f8f9fa;
        transform: translateY(-1px);
        transition: all 0.2s ease;
    }

    .btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
    }

        .btn-primary:hover {
            background: linear-gradient(135deg, #764ba2 0%, #667eea 100%);
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(118, 75, 162, 0.4);
        }
</style>