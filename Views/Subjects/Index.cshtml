@model IEnumerable<PhotocopySystem.Models.Subject>

@{
    ViewData["Title"] = "University Subjects";
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col">
            <h2 class="text-secondary"><i class="bi bi-book me-2"></i>Subject Management</h2>
            <p class="text-muted small">Admin role: Define the subjects taught in the university.</p>
        </div>
        <div class="col text-end">
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg me-1"></i>Add New Subject
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>Subject Name</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 text-muted small">#@item.Id</td>
                            <td class="fw-bold">@item.Name</td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center py-4 text-muted">No subjects found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
