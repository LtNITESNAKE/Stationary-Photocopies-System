@model PhotocopySystem.Models.Review

@{
    ViewData["Title"] = "Write a Review";
}

<div class="container mt-5 mb-5 d-flex justify-content-center">
    <div class="card shadow-lg border-0" style="border-radius: 20px; width: 100%; max-width: 600px;">

        <!-- Header Section -->
        <div class="card-header text-center text-white py-4"
             style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                    border-top-left-radius: 20px; border-top-right-radius: 20px;">
            <h3 class="mb-0 fw-bold">Write a Product Review</h3>
            <p class="mb-0 text-white-50 small">Share your experience about a product below.</p>
        </div>

        <div class="card-body p-5 bg-white">
            <form asp-action="Create" method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <!-- Dropdown: Product -->
                <div class="form-floating mb-4">
                    <select asp-for="ProductId"
                            asp-items="ViewBag.ProductId"
                            class="form-select custom-input">
                        <option value="">-- Select a Product --</option>
                    </select>
                    <label asp-for="ProductId" class="text-muted">Product</label>
                    <span asp-validation-for="ProductId" class="text-danger small mt-1 d-block"></span>
                </div>

                <!-- Dropdown: Rating -->
                <div class="form-floating mb-4">
                    <select asp-for="Rating" class="form-select custom-input">
                        <option value="">-- Select Rating --</option>
                        <option value="1">1 ⭐ – Poor</option>
                        <option value="2">2 ⭐⭐ – Below Average</option>
                        <option value="3">3 ⭐⭐⭐ – Average</option>
                        <option value="4">4 ⭐⭐⭐⭐ – Good</option>
                        <option value="5">5 ⭐⭐⭐⭐⭐ – Excellent</option>
                    </select>
                    <label asp-for="Rating" class="text-muted">Rating (1–5)</label>
                    <span asp-validation-for="Rating" class="text-danger small mt-1 d-block"></span>
                </div>

                <!-- Textarea: Comment -->
                <div class="form-floating mb-4">
                    <textarea asp-for="Comment"
                              class="form-control custom-input"
                              placeholder="Write your comment here..."
                              style="height: 130px; resize: none;"></textarea>
                    <label asp-for="Comment" class="text-muted">Comment</label>
                    <span asp-validation-for="Comment" class="text-danger small mt-1 d-block"></span>
                </div>

                <!-- Buttons -->
                <div class="d-flex justify-content-between align-items-center mt-5">
                    <a asp-action="Index" class="btn btn-light rounded-pill px-4 py-2 fw-semibold text-secondary">
                        <i class="bi bi-arrow-left me-1"></i> Back to List
                    </a>
                    <button type="submit" class="btn btn-primary rounded-pill px-5 py-2 fw-bold shadow-sm custom-btn">
                        Submit Review <i class="bi bi-check2 ms-1"></i>
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

<style>
    .custom-input {
        border-radius: 12px;
        border: 1px solid #e0e0e0;
        background-color: #fcfcfc;
        transition: all 0.3s ease;
    }
    .custom-input:focus {
        border-color: #764ba2;
        box-shadow: 0 0 0 4px rgba(118, 75, 162, 0.1);
        background-color: #ffffff;
    }
    .custom-btn {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        transition: all 0.3s ease;
    }
    .custom-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(118, 75, 162, 0.4) !important;
        background: linear-gradient(135deg, #764ba2 0%, #667eea 100%);
    }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}