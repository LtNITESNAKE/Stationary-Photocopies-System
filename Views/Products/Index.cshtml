@model IEnumerable<PhotocopySystem.Models.Product>

@{
    ViewData["Title"] = "Product Management";
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col">
            <h2 class="fw-bold text-secondary"><i class="bi bi-tags me-2"></i>Product Management</h2>
            <p class="text-muted">Admin: Manage stationery products and pricing.</p>
        </div>
        <div class="col text-end">
            <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Add New Product</a>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 py-3">Name</th>
                            <th class="py-3">Category</th>
                            <th class="py-3">Price</th>
                            <th class="text-center py-3 pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="align-middle">
                                <td class="ps-4 fw-bold">@item.Name</td>
                                <td><span class="badge bg-info text-dark">@item.Category?.Name</span></td>
                                <td class="fw-bold text-success">Rs. @item.Price.ToString("F2")</td>
                                <td class="text-center pe-4">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary me-1">Edit</a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                                onclick="return confirm('Are you sure?')">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-4 text-muted">No products added yet.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
