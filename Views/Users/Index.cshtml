@model IEnumerable<PhotocopySystem.Models.User>

@{
    ViewData["Title"] = "Member Management";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col">
            <h2 class="fw-bold text-secondary"><i class="bi bi-people me-2"></i>University Members</h2>
            <p class="text-muted">Admin: Manage roles and accounts for all team members.</p>
        </div>
        <div class="col text-end">
            <a asp-action="Create" class="btn btn-dark fw-bold">
                <i class="bi bi-person-plus me-2"></i>Create User
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-1"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 py-3">Full Name</th>
                            <th class="py-3">Email Address</th>
                            <th class="py-3">System Role</th>
                            <th class="py-3">Join Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="align-middle">
                                <td class="ps-4 fw-bold">@item.FullName</td>
                                <td>@item.Email</td>
                                <td>
                                    @{
                                        var roleBadge = item.Role == "Admin" ? "bg-danger" : (item.Role == "Teacher" ? "bg-success" : "bg-primary");
                                    }
                                    <span class="badge @roleBadge">@item.Role</span>
                                </td>
                                <td>@item.CreatedAt.ToShortDateString()</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
