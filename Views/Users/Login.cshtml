@{
    ViewData["Title"] = "Login";
    Layout = "_Layout"; // Or null if you don't want the top navbar on the login screen
}

<!-- GOLDEN EXAMPLE: Premium Login Screen -->
<div class="container mt-5 mb-5 d-flex justify-content-center">
    <div class="card shadow-lg border-0" style="border-radius: 20px; width: 100%; max-width: 450px;">
        
        <div class="card-header text-center text-white py-5" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-top-left-radius: 20px; border-top-right-radius: 20px;">
            <i class="bi bi-person-circle display-4 mb-3 d-block"></i>
            <h3 class="mb-0 fw-bold">Welcome Back</h3>
            <p class="mb-0 text-white-50">Please login to your account.</p>
        </div>

        <div class="card-body p-5 bg-white">
            <form asp-action="Login" method="post">
                
                <div class="form-floating mb-4">
                    <input name="email" type="email" class="form-control custom-input" placeholder="name@example.com" required />
                    <label class="text-muted"><i class="bi bi-envelope me-2"></i>Email Address</label>
                </div>

                <div class="form-floating mb-4">
                    <input name="password" type="password" class="form-control custom-input" placeholder="Password" required />
                    <label class="text-muted"><i class="bi bi-lock me-2"></i>Password</label>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="rememberMe">
                        <label class="form-check-label text-muted small" for="rememberMe">
                            Remember me
                        </label>
                    </div>
                    <a href="#" class="text-decoration-none small fw-semibold" style="color: #764ba2;">Forgot Password?</a>
                </div>

                <button type="submit" class="btn btn-primary w-100 rounded-pill py-3 fw-bold shadow-sm custom-btn mb-3">
                    Login <i class="bi bi-box-arrow-in-right ms-2"></i>
                </button>
                
                <p class="text-center text-muted small">
                    Don't have an account? <a asp-action="Create" class="text-decoration-none fw-bold" style="color: #667eea;">Sign Up</a>
                </p>
            </form>
        </div>
    </div>
</div>

<style>
    .custom-input {
        border-radius: 12px;
        border: 1px solid #e0e0e0;
        background-color: #fcfcfc;
        transition: all 0.3s ease;
    }
    .custom-input:focus {
        border-color: #764ba2;
        box-shadow: 0 0 0 4px rgba(118, 75, 162, 0.1);
        background-color: #ffffff;
    }
    .custom-btn {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        transition: all 0.3s ease;
    }
    .custom-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(118, 75, 162, 0.4) !important;
        background: linear-gradient(135deg, #764ba2 0%, #667eea 100%);
    }
</style>
