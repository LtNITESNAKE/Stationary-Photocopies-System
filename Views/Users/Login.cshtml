@model PhotocopySystem.Models.User

@{
    ViewData["Title"] = "Login";
    Layout = "_Layout";
}

<div class="row justify-content-center">
    <div class="col-md-4">
        <div class="card shadow border-0 mt-5">
            <div class="card-header bg-primary text-white text-center py-3">
                <h4 class="mb-0 fw-bold">Sign In</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="Login" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold small">University Email</label>
                        <input name="email" type="email" class="form-control" required placeholder="name@univ.com" />
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Password</label>
                        <input name="password" type="password" class="form-control" required placeholder="••••••••" />
                    </div>
                    
                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn btn-primary fw-bold">Login to Portal</button>
                        <a asp-action="Signup" class="btn btn-link text-muted small">Create New Account</a>
                    </div>
                </form>
            </div>
        </div>
        
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
