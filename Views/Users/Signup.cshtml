@model PhotocopySystem.Models.User

@{
    ViewData["Title"] = "Create Account";
    Layout = "_Layout";
}

<div class="auth-container">
    <div class="card shadow-sm">
        <div class="card-header text-center py-3">
            <h4 class="mb-0 text-primary">Sign Up</h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="Signup" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                
                <div class="mb-3">
                    <label asp-for="FullName" class="form-label">Full Name</label>
                    <input asp-for="FullName" class="form-control" placeholder="John Doe" />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label">University Email</label>
                    <input asp-for="Email" class="form-control" placeholder="name@univ.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                
                <div class="mb-3">
                    <label asp-for="PasswordHash" class="form-label">Create Password</label>
                    <input asp-for="PasswordHash" type="password" class="form-control" placeholder="••••••••" />
                    <span asp-validation-for="PasswordHash" class="text-danger small"></span>
                </div>
                
                <div class="d-grid gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">Register Account</button>
                    <a asp-action="Login" class="btn btn-link text-muted small">Already have an account? Login</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
