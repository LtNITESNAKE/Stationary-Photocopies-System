@model IEnumerable<PhotocopySystem.Models.InventoryStock>

@{
    ViewData["Title"] = "Inventory Stock";
}

<!-- TODO for Noor: -->
<!-- 1. Use the Users/Index.cshtml template. -->
<!-- 2. Display Product Name and QuantityAvailable. -->

<div class="container mt-5">
    <h2><i class="bi bi-boxes"></i> Live Inventory Levels</h2>
    <hr />
    <p class="text-muted">Noor, build your stock table here!</p>
    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>Product Name</th>
                <th>Quantity Available</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Product?.Name</td>
                <td>@item.QuantityAvailable</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-primary btn-sm">
                        Edit
                    </a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
