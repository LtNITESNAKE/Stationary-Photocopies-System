@model IEnumerable<PhotocopySystem.Models.InventoryStock>

@{
    ViewData["Title"] = "Stationery Shop";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col">
            <h2 class="fw-bold text-secondary"><i class="bi bi-cart4 me-2"></i>Stationery & Supplies</h2>
            <p class="text-muted">Purchase pens, paper, and other university essentials.</p>
        </div>
        @if (User.IsInRole("Admin"))
        {
            <div class="col text-end">
                <a asp-controller="Products" asp-action="Index" class="btn btn-outline-secondary me-1">
                    <i class="bi bi-gear me-1"></i>Manage Products
                </a>
                <a asp-controller="Categories" asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-tags me-1"></i>Categories
                </a>
            </div>
        }
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-1"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle me-1"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="badge bg-info text-dark">@item.Product?.Category?.Name</span>
                            <h5 class="fw-bold text-primary mb-0">Rs. @item.Product?.Price</h5>
                        </div>
                        <h5 class="card-title fw-bold">@item.Product?.Name</h5>
                        
                        <div class="d-flex align-items-center mt-3">
                            <div class="me-auto small text-muted">
                                <i class="bi bi-box-seam me-1"></i> Stock: 
                                <span class="fw-bold @(item.QuantityAvailable < 10 ? "text-danger" : "text-success")">
                                    @item.QuantityAvailable
                                </span>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 pb-3">
                        @if (item.QuantityAvailable > 0)
                        {
                            <form asp-controller="Orders" asp-action="Create" method="post">
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <div class="input-group mb-2">
                                    <span class="input-group-text bg-light">Qty</span>
                                    <input type="number" name="quantity" value="1" min="1" 
                                           max="@item.QuantityAvailable" class="form-control" />
                                </div>
                                <button type="submit" class="btn btn-primary w-100 fw-bold rounded-pill">
                                    <i class="bi bi-bag-plus me-2"></i>Purchase Now
                                </button>
                            </form>
                        }
                        else
                        {
                            <button class="btn btn-secondary w-100 disabled rounded-pill">Out of Stock</button>
                        }

                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary w-100 mt-2">
                                <i class="bi bi-pencil me-1"></i>Edit Stock
                            </a>
                        }
                    </div>
                </div>
            </div>
        }
        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5">
                <i class="bi bi-inbox text-muted display-1"></i>
                <p class="text-muted mt-3">No products in stock. Admin must add Products and Stock first.</p>
            </div>
        }
    </div>
</div>
