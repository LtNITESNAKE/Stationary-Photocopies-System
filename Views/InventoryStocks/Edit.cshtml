@model PhotocopySystem.Models.InventoryStock

@{
    ViewData["Title"] = "Update Stock";
}

<!-- TODO for Noor (Concurrency Stock Update): -->
<!-- 1. Use the Users/Create.cshtml template. -->
<!-- 2. Add an input for QuantityAvailable. -->
<!-- IMPORTANT: You must include a hidden field for RowVersion to handle Concurrency if a Student buys exactly when you update! -->
<!-- <input type="hidden" asp-for="RowVersion" /> -->

<div class="container mt-5">
    <h2><i class="bi bi-arrow-repeat"></i> Update Stock Quantity</h2>
    <hr />
     <form asp-action="Edit" method="post">

        
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="RowVersion" />

        
        <div class="form-group mb-3">
            <label>Product</label>
            <input class="form-control" value="@Model.Product?.Name" readonly />
        </div>

        
        <div class="form-group mb-3">
            <label asp-for="QuantityAvailable"></label>
            <input asp-for="QuantityAvailable" class="form-control" />
            <span asp-validation-for="QuantityAvailable" class="text-danger"></span>
        </div>

        
        <div asp-validation-summary="All" class="text-danger"></div>

        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-secondary">Back</a>

    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <p class="text-muted">Noor, build your update form here. Remember the hidden RowVersion!</p>
    }
