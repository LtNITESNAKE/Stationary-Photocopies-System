@model PhotocopySystem.Models.InventoryStock

@{
    ViewData["Title"] = "Update Stock";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-arrow-repeat me-2"></i>Update Stock Quantity</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="RowVersion" />
                        <input type="hidden" asp-for="ProductId" />

                        <div class="mb-3">
                            <label class="form-label fw-bold">Product</label>
                            <input class="form-control" value="@Model.Product?.Name" readonly />
                        </div>

                        <div class="mb-4">
                            <label asp-for="QuantityAvailable" class="form-label fw-bold">Quantity Available</label>
                            <input asp-for="QuantityAvailable" class="form-control" />
                            <span asp-validation-for="QuantityAvailable" class="text-danger small"></span>
                        </div>

                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-1"></i>Back
                            </a>
                            <button type="submit" class="btn btn-primary px-4">Save Changes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
