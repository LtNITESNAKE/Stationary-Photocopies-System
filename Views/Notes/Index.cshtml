@model IEnumerable<PhotocopySystem.Models.Note>

@{
    ViewData["Title"] = "University Notes & Assignments";
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col">
            <h2 class="text-secondary"><i class="bi bi-file-earmark-text me-2"></i>Library of Notes</h2>
            <p class="text-muted small">Select a note to see details. You can request copies from the Print Queue.</p>
        </div>
        @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
        {
            <div class="col text-end">
                <a asp-action="Create" class="btn btn-success">
                    <i class="bi bi-cloud-arrow-up me-1"></i>Upload New Note
                </a>
            </div>
        }
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="badge bg-primary bg-opacity-10 text-primary">@item.Subject?.Name</span>
                            <div class="d-flex align-items-center">
                                <span class="text-muted small me-2">v@(item.Version)</span>
                                @if (User.IsInRole("Admin") || (User.IsInRole("Teacher") && item.TeacherId.ToString() == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value))
                                {
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Delete this note permanently?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-link text-danger p-0 border-0">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                        <h5 class="card-title fw-bold">@item.Title</h5>
                        <p class="card-text text-muted small mb-1">Uploaded by: <strong>@item.Teacher?.FullName</strong></p>
                        
                        @{
                            bool currentlyLocked = item.IsLocked && item.ReleaseTime.HasValue && DateTime.Now < item.ReleaseTime.Value;
                        }

                        @if (currentlyLocked)
                        {
                            <div class="text-danger small mt-2 lock-message" data-unlock-time="@item.ReleaseTime?.ToString("yyyy-MM-ddTHH:mm:ss")">
                                <i class="bi bi-lock-fill me-1"></i> Locked until: @item.ReleaseTime?.ToString("dd MMM, hh:mm tt")
                            </div>
                        }
                    </div>
                    <div class="card-footer bg-transparent border-0 pb-3">
                        @if (currentlyLocked && User.IsInRole("Student"))
                        {
                            <div class="lock-container" data-unlock-time="@item.ReleaseTime?.ToString("yyyy-MM-ddTHH:mm:ss")">
                                <button class="btn btn-sm btn-secondary w-100 locked-btn" disabled>
                                    <i class="bi bi-lock me-1"></i> Locked
                                </button>
                                <a asp-controller="PrintJobs" asp-action="Create" asp-route-noteId="@item.Id" class="btn btn-sm btn-outline-primary w-100 unlock-btn d-none">
                                    Request Photocopies
                                </a>
                            </div>
                        }
                        else
                        {
                            <a asp-controller="PrintJobs" asp-action="Create" asp-route-noteId="@item.Id" class="btn btn-sm btn-outline-primary w-100">
                                Request Photocopies
                            </a>
                        }
                    </div>
                </div>
            </div>
        }
        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5">
                <i class="bi bi-inbox text-muted display-1"></i>
                <p class="text-muted mt-3">No notes have been uploaded yet.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function checkLocks() {
            const now = new Date();
            
            // 1. Handle the "Locked" button (for Students)
            document.querySelectorAll('.lock-container').forEach(container => {
                const unlockTimeStr = container.getAttribute('data-unlock-time');
                if (unlockTimeStr) {
                    const unlockTime = new Date(unlockTimeStr);
                    if (now >= unlockTime) {
                        container.querySelector('.locked-btn').classList.add('d-none');
                        container.querySelector('.unlock-btn').classList.remove('d-none');
                    }
                }
            });

            // 2. Handle the red "Locked until" message (for Everyone)
            document.querySelectorAll('.lock-message').forEach(msg => {
                const unlockTimeStr = msg.getAttribute('data-unlock-time');
                if (unlockTimeStr) {
                    const unlockTime = new Date(unlockTimeStr);
                    if (now >= unlockTime) {
                        msg.classList.add('d-none');
                    }
                }
            });
        }

        setInterval(checkLocks, 1000);
        document.addEventListener('DOMContentLoaded', checkLocks);
    </script>
}
