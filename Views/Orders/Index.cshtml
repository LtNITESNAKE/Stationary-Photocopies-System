@model IEnumerable<PhotocopySystem.Models.Order>

@{
    ViewData["Title"] = "Order History";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col">
            <h2 class="fw-bold text-secondary"><i class="bi bi-bag-check me-2"></i>@(User.IsInRole("Admin") ? "All Stationery Orders" : "Your Orders")</h2>
            <p class="text-muted">@(User.IsInRole("Admin") ? "View all student stationery purchases." : "View your recent stationery purchases.")</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 py-3">Order ID</th>
                            @if (User.IsInRole("Admin"))
                            {
                                <th class="py-3">Student Name</th>
                            }
                            <th class="py-3">Date</th>
                            <th class="py-3">Total Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="align-middle">
                                <td class="ps-4 fw-bold">#ORD-@item.Id</td>
                                @if (User.IsInRole("Admin"))
                                {
                                    <td>@item.User?.FullName</td>
                                }
                                <td>@item.OrderDate.ToString("dd MMM yyyy, hh:mm tt")</td>
                                <td class="fw-bold text-success">Rs. @item.TotalAmount.ToString("F2")</td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="3" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox display-4 d-block mb-3"></i>
                                    No orders found yet. Visit the shop to buy stationery!
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>