@model PhotocopySystem.Models.PrintJob

@{
    ViewData["Title"] = "Submit Print Job";
}

<!-- TODO for Maryam (Student Print Request Form): -->
<!-- 1. Use the Users/Create.cshtml template. -->
<!-- 2. Add inputs for NoteId (Dropdown), DocumentName, and Copies. -->

<div class="container mt-5">
    <h2><i class="bi bi-cloud-arrow-up"></i> Submit Document for Printing</h2>
    <hr />
    <p class="text-muted">Maryam, build your upload form here!</p>
    <form asp-action="Create" method="post">

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label class="form-label">Select Note</label>
            <select asp-for="NoteId" class="form-control">
                <option value="">-- Select Note --</option>
                @if (ViewBag.Notes != null)
                {
                    foreach (var note in (IEnumerable<PhotocopySystem.Models.Note>)ViewBag.Notes)
                    {
                        <option value="@note.Id">@note.Title</option>
                    }
                }
            </select>
            <span asp-validation-for="NoteId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="DocumentName" class="form-label"></label>
            <input asp-for="DocumentName" class="form-control" placeholder="Enter document name" />
            <span asp-validation-for="DocumentName" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Copies" class="form-label"></label>
            <input asp-for="Copies" type="number" class="form-control" placeholder="Enter number of copies" />
            <span asp-validation-for="Copies" class="text-danger"></span>
        </div>

        <input type="hidden" asp-for="StudentId" value="1" />

        <button type="submit" class="btn btn-primary">
            <i class="bi bi-printer"></i> Submit Print Job
        </button>

    </form>
</div>
