@model IEnumerable<PhotocopySystem.Models.PrintJob>

@{
    ViewData["Title"] = "Print Queue";
}

<!-- TODO for Maryam (Print Queue Dashboard): -->
<!-- 1. Use the Users/Index.cshtml template. -->
<!-- 2. Display Student.FullName, Note.Title, Copies, Status, and EstimatedPickupTime. -->

<div class="container mt-5">
    <h2><i class="bi bi-printer"></i> Background Print Queue</h2>
    <hr />
    <p class="text-muted">Maryam, build your queue table here!</p>
    <div class="card shadow-lg border-0" style="border-radius: 15px; overflow: hidden;">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
                        <tr>
                            <th class="py-3 px-4">StudentId</th>
                            <th class="py-3 px-4">Student</th>
                            <th class="py-3 px-4">NoteId</th>
                            <th class="py-3 px-4">Note / Document</th>
                            <th class="py-3 px-4 text-center">Copies</th>
                            <th class="py-3 px-4">Status</th>
                            <th class="py-3 px-4">Pickup Time</th>
                            <th class="py-3 px-4 text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="px-4 text-primary fw-bold">
                                    @item.StudentId
                                </td>

                                <td class="px-4 fw-semibold text-dark">
                                    @item.Student?.FullName
                                </td>

                                <td class="px-4 text-muted">
                                    @(item.NoteId.HasValue? item.NoteId.ToString() : "N/A")
                                </td>

                                <td class="px-4 text-muted">
                                    @(item.Note != null ? item.Note.Title : item.DocumentName)
                                </td>

                                <td class="px-4 text-center">
                                    <span class="badge bg-secondary px-3 py-2 rounded-pill">@item.Copies</span>
                                </td>

                                <td class="px-4">
                                    @{
                                        string badgeClass = item.Status == "Completed" ? "bg-success" :
                                        item.Status == "Printing" ? "bg-warning text-dark" : "bg-info text-white";
                                    }
                                    <span class="badge @badgeClass px-3 py-2 rounded-pill">@item.Status</span>
                                </td>

                                <td class="px-4 text-muted">
                                    @item.EstimatedPickupTime.ToString("HH:mm")
                                </td>

                                <td class="px-4 text-center">
                                    <form asp-action="Cancel" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Cancel Job #@item.Id?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill">
                                            <i class="bi bi-x-circle"></i> Cancel
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    /* Styling to match the Project Leader's Template */
    .table-hover tbody tr:hover {
        background-color: #f8f9fa;
        transform: translateY(-1px);
        transition: all 0.2s ease;
    }
    .btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
    }
</style>
</div>
