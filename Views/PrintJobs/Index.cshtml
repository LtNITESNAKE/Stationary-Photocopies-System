@model IEnumerable<PhotocopySystem.Models.PrintJob>

@{
    ViewData["Title"] = "Photocopy Queue";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col">
            <h2 class="fw-bold text-secondary"><i class="bi bi-printer me-2"></i>Photocopy Printing Queue</h2>
            <p class="text-muted">Monitor your requests and estimated pickup times.</p>
        </div>
        <div class="col text-end">
            <a asp-action="Create" class="btn btn-primary fw-bold px-4">
                <i class="bi bi-plus-lg me-2"></i>Request New Copies
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-1"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Warning"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-1"></i> @TempData["Warning"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle me-1"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 py-3">Student Name</th>
                            <th class="py-3">Document / Note</th>
                            <th class="py-3">Copies</th>
                            <th class="py-3">Status</th>
                            <th class="py-3">Fine (PKR)</th>
                            <th class="py-3">Pickup Time</th>
                            <th class="text-center py-3 pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="align-middle">
                                <td class="ps-4 fw-bold">@item.Student?.FullName</td>
                                <td>
                                    <div class="fw-bold">@(item.Note != null ? item.Note.Title : item.DocumentName)</div>
                                    <div class="text-muted small">ID: #PJ-@item.Id</div>
                                </td>
                                <td><span class="badge bg-secondary">@item.Copies</span></td>
                                <td>
                                    @{
                                        var badgeClass = item.Status switch
                                        {
                                            "Completed" => "bg-success",
                                            "Printing" => "bg-primary",
                                            "Cancelled" => "bg-danger",
                                            _ => "bg-warning text-dark"
                                        };
                                    }
                                    <span id="status-@item.Id" class="badge @badgeClass">@item.Status</span>
                                </td>
                                <td class="fw-bold @(item.FineAmount > 0 ? "text-danger" : "text-muted")">
                                    @(item.FineAmount > 0 ? "Rs. " + item.FineAmount : "-")
                                </td>
                                <td>@item.EstimatedPickupTime.ToString("hh:mm tt")</td>
                                <td class="text-center pe-4">
                                    @if (item.Status == "Queued" || item.Status == "Printing")
                                    {
                                        <form asp-action="Cancel" asp-route-id="@item.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger px-3 rounded-pill" 
                                                    onclick="return confirm('Are you sure you want to cancel this order?')">
                                                Cancel
                                            </button>
                                        </form>
                                    }

                                    @if (User.IsInRole("Admin"))
                                    {
                                        <div class="dropdown d-inline">
                                            <button class="btn btn-sm btn-outline-secondary dropdown-toggle px-3 ms-1 rounded-pill"
                                                    type="button" data-bs-toggle="dropdown">
                                                Set Status
                                            </button>
                                            <ul class="dropdown-menu">
                                                @foreach (var s in new[] { "Queued", "Printing", "Completed", "Cancelled" })
                                                {
                                                    <li>
                                                        <form asp-action="UpdateStatus" method="post" class="d-inline">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="id" value="@item.Id" />
                                                            <input type="hidden" name="newStatus" value="@s" />
                                                            <button type="submit" class="dropdown-item">@s</button>
                                                        </form>
                                                    </li>
                                                }
                                            </ul>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox display-4 d-block mb-3"></i>
                                    No print jobs found in the queue.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- SignalR Toast Notification Container -->
<div class="toast-container position-fixed bottom-0 end-0 p-3">
    <div id="liveToast" class="toast" role="alert">
        <div class="toast-header">
            <strong class="me-auto"><i class="bi bi-printer me-1"></i> Print Update</strong>
            <button type="button" class="btn-close" data-bs-dismiss="toast"></button>
        </div>
        <div class="toast-body" id="toastBody"></div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="~/js/signalr-client.js"></script>
}
